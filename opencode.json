{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    }
  },
  "permission": {
    "bash": {
      "*": "ask",
      "ls": "allow",
      "grep": "allow",
      "bun run build": "allow"
    }
  }
}
